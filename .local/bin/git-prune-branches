#!/bin/bash

# Build a map of full branch ref -> worktree path
get_worktree_map() {
    declare -gA branch_to_worktree=()
    local path="" branch=""
    while IFS= read -r line; do
        case "$line" in
            worktree\ *) path="${line#worktree }" ; branch="" ;;
            branch\ *)   branch="${line#branch }" ;;
            "")          [[ -n $branch ]] && branch_to_worktree["$branch"]="$path" ;;
        esac
    done < <(git worktree list --porcelain; echo)
}

get_worktree_map

# Remove worktrees and branches whose upstream is gone
while IFS= read -r refname; do
    short="${refname#refs/heads/}"
    path="${branch_to_worktree[$refname]}"
    if [[ -n $path ]]; then
        echo "Removing worktree for gone-upstream branch: $short"
        git worktree remove --force "$path" || { echo "Failed to remove worktree: $path"; continue; }
    fi
    echo "Deleting gone-upstream branch: $short"
    git branch -D "$short"
done < <(git for-each-ref --format='%(refname) %(upstream:track)' refs/heads/ | awk '$2 == "[gone]" {print $1}')

# Refresh map after any worktree removals
get_worktree_map

# Delete branches not checked out in any remaining worktree
for refname in $(git for-each-ref --format='%(refname)' refs/heads/); do
    short="${refname#refs/heads/}"
    if [[ -z "${branch_to_worktree[$refname]}" ]]; then
        echo "Deleting unused branch: $short"
        git branch -D "$short"
    else
        echo "Skipping checked-out branch: $short"
    fi
done
